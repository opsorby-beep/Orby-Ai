{
  "entities": {
    "Contractor": {
      "title": "Contractor Profile",
      "description": "Onboarded contractor profile metadata",
      "type": "object",
      "properties": {
        "businessName": { "type": "string" },
        "whatsapp": { "type": "string" },
        "website": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zip": { "type": "string" },
        "primaryTrade": { "type": "string" },
        "themeKey": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["businessName"]
    },
    "Estimate": {
      "title": "Estimate Result",
      "description": "Estimate or Invoice generated by the contractor",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "contractorId": { "type": "string" },
        "createdAt": { "type": "string" },
        "clientName": { "type": "string" },
        "clientAddress": { "type": "string" },
        "description": { "type": "string" },
        "totalCost": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["id", "contractorId", "createdAt"]
    }
  },
  "firestore": {
    "contractors/{id}": {
      "schema": "Contractor",
      "description": "Onboarded contractor profiles"
    },
    "estimates/{id}": {
      "schema": "Estimate",
      "description": "Estimates and invoices generated by contractors"
    }
  }
}
